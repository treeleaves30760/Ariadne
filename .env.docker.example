# Copy to .env at the repo root for `docker compose`.

# OpenAlex polite-pool email (recommended) and optional Semantic Scholar key.
PC_OPENALEX_EMAIL=you@example.com
PC_SEMANTIC_SCHOLAR_API_KEY=

# Bypass Codex's OS sandbox inside the container (container is the isolation boundary).
PC_CODEX_BYPASS_SANDBOX=1

# Port Caddy publishes on the host (change to 80, or put a domain in the Caddyfile, for a server).
PUBLIC_PORT=8080
