# Copy to backend/.env and fill in. All keys are prefixed PC_.

# Semantic Scholar API key (optional — raises rate limits). Leave blank for the public pool.
PC_SEMANTIC_SCHOLAR_API_KEY=

# Email for the OpenAlex "polite pool" (recommended).
PC_OPENALEX_EMAIL=you@example.com

# Codex CLI: authentication is taken from your local `codex login`; no API key here.
# Optionally pin a model:
# PC_CODEX_MODEL=
PC_CODEX_CONCURRENCY=3

# Expansion defaults (loose preset)
PC_PER_LEVEL_K=80
PC_RELEVANCE_THRESHOLD=0.25

# Global hard ceilings (cost/time guardrails)
PC_MAX_NODES=600
PC_MAX_CODEX_CALLS=200

# Storage
PC_DB_PATH=paper_connector.db
